# ============================================================
# Hamplard Backend — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://hamplard:password@localhost:5432/hamplard_db

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed Hamplard contract ID (from hamplard-contract deploy)
HAMPLARD_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
USDC_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Admin Stellar address — must match the admin set at contract init
ADMIN_STELLAR_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Platform treasury address — receives platform fee share
TREASURY_STELLAR_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# File storage (local for dev — swap for S3/Cloudinary in production)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@hamplard.com

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Event polling interval (ms)
EVENT_POLLING_INTERVAL_MS=5000

# CORS — frontend origin
CORS_ORIGIN=http://localhost:3001

# Certificate issuer name (appears in email notifications)
PLATFORM_NAME=Hamplard
